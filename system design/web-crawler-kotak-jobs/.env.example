# Application Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/kotak-jobs
MONGODB_DATABASE=kotak-jobs
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
MONGO_MAX_IDLE_TIME_MS=60000
MONGO_WAIT_QUEUE_TIMEOUT_MS=10000
MONGO_CONNECT_TIMEOUT_MS=10000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=kotak-crawler:

# Crawler Configuration
KOTAK_CAREER_URL=https://www.kotak.com/careers
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
REQUEST_TIMEOUT=30000
MAX_REDIRECTS=5

# Rate Limiting
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_RATE=10
RATE_LIMIT_MIN_DELAY=100

# Retry Configuration
MAX_RETRIES=3
RETRY_INITIAL_DELAY=1000
RETRY_MAX_DELAY=30000
RETRY_BACKOFF_MULTIPLIER=2

# Worker Configuration
WORKER_COUNT=10
MAX_WORKERS=50
MIN_WORKERS=2

# HTTP Connection Pool
HTTP_MAX_SOCKETS=100
HTTP_MAX_FREE_SOCKETS=10
HTTP_TIMEOUT=60000
HTTP_KEEP_ALIVE_MS=1000

# Caching
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Pagination
MAX_PAGES=50

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true
LOG_COLORIZE=true

# Scheduling
SCHEDULING_ENABLED=true
CRAWL_SCHEDULE=0 */30 * * * *
TIMEZONE=Asia/Kolkata

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT=60000
CB_MONITORING_PERIOD=10000

# Batch Processing
BATCH_ENABLED=true
BATCH_SIZE=100
BATCH_TIMEOUT=5000

# Monitoring
MONITORING_ENABLED=true
METRICS_INTERVAL=60000